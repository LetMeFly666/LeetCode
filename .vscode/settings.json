{
    "files.associations": {
        "*.pro": "plaintext",
        "*.wxss": "css",
        "*.wxml": "html",
        ".commitmsg": "git-commit",
        ".commitTitleExtra": "git-commit"
    },
    "files.watcherExclude": {
        "**/AllProblems/**": true
    },
    "editor.mouseWheelZoom": true,
    "workbench.tree.enableStickyScroll": true,
    "github.copilot.enable": {
        "*": false
    }
}